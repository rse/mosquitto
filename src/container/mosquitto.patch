Index: lib/send_publish.c
--- lib/send_publish.c.orig	2026-02-09 10:29:46
+++ lib/send_publish.c	2026-05-14 00:38:10
@@ -41,6 +41,39 @@
 #include "utlist.h"
 
 
+static char *publish__format_payload(const void *payload, uint32_t payloadlen)
+{
+	const unsigned char *p = (const unsigned char *)payload;
+	uint32_t i;
+	uint32_t outlen = 1;
+	char *out;
+	char *w;
+
+	for(i = 0; i < payloadlen; i++){
+		if(p[i] >= 0x20 && p[i] <= 0x7E){
+			outlen += 1;
+		}else{
+			outlen += 4;
+		}
+	}
+	out = mosquitto_malloc(outlen);
+	if(!out){
+		return NULL;
+	}
+	w = out;
+	for(i = 0; i < payloadlen; i++){
+		if(p[i] >= 0x20 && p[i] <= 0x7E){
+			*w++ = (char)p[i];
+		}else{
+			snprintf(w, 5, "\\x%02X", p[i]);
+			w += 4;
+		}
+	}
+	*w = '\0';
+	return out;
+}
+
+
